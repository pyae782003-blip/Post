# ─────────────────────────────────────────────
# Neon PostgreSQL connection strings
# Get these from your Neon project dashboard:
# https://console.neon.tech
# ─────────────────────────────────────────────

# Pooled connection (used by Prisma at runtime via PgBouncer)
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct connection (used for Prisma migrations / db push)
DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"
